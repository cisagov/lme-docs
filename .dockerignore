# .dockerignore — LME Docs
#
# Excludes files that are not needed in the Docker build context,
# reducing transfer size and preventing secrets from leaking into layers.

# Version control and CI
.git
.github
.agent
.claude
.worktrees

# Docker files themselves (not needed in the image)
Dockerfile
docker-compose.yml
.dockerignore

# Build artifacts (builder stage runs npm run build from source)
node_modules
build
.docusaurus

# Markdown files at the root — exclude all but keep docs/ and blog/ content
*.md
!docs/**/*.md
!blog/**/*.md
!README.md

# Development / tooling artifacts
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db
.vscode/
.idea/
tmp/

# Hugo artifacts (legacy, should already be removed)
public/
resources/
content/
hugo.toml
go.mod
go.sum
